---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
	description?: string;
	/** Ruta bajo /public para vista previa en WhatsApp, Facebook, etc. (Open Graph). */
	ogImage?: string;
}

const {
	title,
	description = 'Manuel Parada — obra y trayectoria.',
	ogImage = '/og-social.png',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage.replace(/^\//, ''), Astro.site);
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=DM+Sans:wght@500;600&display=swap"
			rel="stylesheet"
		/>
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
		<link rel="canonical" href={canonicalURL.href} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Manuel Parada" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL.href} />
		<meta property="og:image" content={ogImageURL.href} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:type" content="image/png" />
		<meta property="og:image:alt" content="Manuel Parada — escultor" />
		<meta property="og:locale" content="es_VE" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL.href} />
		<ClientRouter />
	</head>
	<body class="min-h-dvh bg-neutral-950 text-neutral-100 antialiased">
		<a
			href="#contenido"
			class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-white focus:px-3 focus:py-2 focus:text-neutral-950"
		>
			Ir al contenido
		</a>
		<slot />
		<footer class="border-t border-white/10 bg-neutral-950/90">
			<div class="mx-auto flex max-w-5xl flex-col items-center gap-4 px-4 py-10 sm:px-6">
				<a href="/" class="opacity-90 transition-opacity hover:opacity-100" aria-label="Manuel Parada, escultor — inicio">
					<img
						src="/logo-marca-apilada.png"
						alt=""
						width="1024"
						height="571"
						class="h-auto max-h-14 w-auto sm:max-h-16"
						loading="lazy"
						decoding="async"
					/>
				</a>
				<p class="text-center text-xs text-neutral-600">Manuel Parada · escultor</p>
			</div>
		</footer>
		<!-- Script clásico (no ES module): WebView de WhatsApp / in-app a veces no ejecuta type=module. -->
		<script is:inline>
			(function () {
				var MOSAIC_MS = 6000;
				var MOSAIC_COUNT = 3;
				var mosaicIntervalId = 0;

				function clearMosaicInterval() {
					if (mosaicIntervalId) {
						window.clearInterval(mosaicIntervalId);
						mosaicIntervalId = 0;
					}
				}

				function initHomeWallOnce() {
					if (window.__mpHomeWallDelegated) return;
					window.__mpHomeWallDelegated = true;
					document.addEventListener(
						'click',
						function (e) {
							var root = document.getElementById('home-wall-section');
							if (!root) return;
							if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
							var wall = root.querySelector('[data-home-wall]');
							if (!wall) return;
							var t = e.target && e.target.closest && e.target.closest('.home-wall-tile');
							if (t && wall.contains(t)) {
								var on = t.getAttribute('aria-pressed') === 'true';
								wall.querySelectorAll('.home-wall-tile').forEach(function (b) {
									b.setAttribute('aria-pressed', 'false');
								});
								if (!on) t.setAttribute('aria-pressed', 'true');
								return;
							}
							wall.querySelectorAll('.home-wall-tile').forEach(function (b) {
								b.setAttribute('aria-pressed', 'false');
							});
						},
						true,
					);
				}

				function initMosaicRotate() {
					clearMosaicInterval();
					var grid = document.querySelector('[data-mosaic-root]');
					if (!grid) return;
					var photoCount = Number(grid.dataset.photoCount || '0');
					if (photoCount < 8) grid.dataset.mosaicLayout = '0';

					function tick() {
						var g = document.querySelector('[data-mosaic-root]');
						if (!g) return;
						var n = Number(g.dataset.photoCount || '0');
						if (n >= 8) {
							var cur = Number(g.dataset.mosaicLayout || '0');
							g.dataset.mosaicLayout = String((cur + 1) % MOSAIC_COUNT);
						}
						var board = g.closest('[data-cork-board]');
						if (board && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
							board.classList.add('home-wall-cork-board--repin');
							window.setTimeout(function () {
								board.classList.remove('home-wall-cork-board--repin');
							}, 420);
						}
					}

					function arm() {
						clearMosaicInterval();
						var g = document.querySelector('[data-mosaic-root]');
						if (!g) return;
						if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
							g.dataset.mosaicLayout = '0';
							return;
						}
						mosaicIntervalId = window.setInterval(tick, MOSAIC_MS);
						if (typeof queueMicrotask === 'function') queueMicrotask(tick);
						else window.setTimeout(tick, 0);
					}
					arm();
				}

				if (!window.__mpMosaicPrm) {
					window.__mpMosaicPrm = true;
					window
						.matchMedia('(prefers-reduced-motion: reduce)')
						.addEventListener('change', initMosaicRotate);
				}

				function scheduleMosaicInit() {
					window.requestAnimationFrame(function () {
						window.requestAnimationFrame(initMosaicRotate);
					});
				}

				function bootHomeWall() {
					initHomeWallOnce();
					scheduleMosaicInit();
				}

				document.addEventListener('astro:page-load', bootHomeWall);
				document.addEventListener('DOMContentLoaded', bootHomeWall);
				window.addEventListener('load', bootHomeWall);
				window.addEventListener('pageshow', bootHomeWall);
				document.addEventListener('visibilitychange', function () {
					if (!document.hidden) scheduleMosaicInit();
				});
				bootHomeWall();
				window.setTimeout(bootHomeWall, 400);
				window.setTimeout(bootHomeWall, 1200);
			})();
		</script>
		<script is:inline>
			(function () {
				if (typeof window === 'undefined') return;
				try {
					if (sessionStorage.getItem('mpConsoleLogo')) return;
					sessionStorage.setItem('mpConsoleLogo', '1');
				} catch {
					/* modo privado u otro bloqueo */
				}

				function pintar() {
					const src = new URL('/logo-parada-monolito.svg', window.location.href).href;
					console.log(
						'%c\n%c Bloque monolítico · Manuel Parada',
						'',
						'font-size:11px;font-family:system-ui,sans-serif;color:#a3a3a3',
					);
					/* Chromium: muestra el SVG como fondo del bloque %c */
					console.log(
						'%c ',
						'font-size:1px;line-height:100px;padding:50px 100px;background:url("' +
							src +
							'") center/contain no-repeat;border-radius:6px',
					);
					console.log(
						'%c P A R A D A ',
						'font-family:Georgia,"Times New Roman",serif;font-weight:700;font-size:12px;letter-spacing:.5em;color:#e8e8e6;background:#171717;padding:8px 12px;border-radius:4px',
					);
				}

				if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', pintar);
				else pintar();
			})();
		</script>
	</body>
</html>
