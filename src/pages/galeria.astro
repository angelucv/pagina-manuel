---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';

type GlobImg = string | { src: string };

function imgUrl(m: GlobImg): string {
	return typeof m === 'string' ? m : m.src;
}

const modules = import.meta.glob<GlobImg>('../../Fotos/*.png', { eager: true, import: 'default' });

const entries = Object.entries(modules).sort(([a], [b]) => a.localeCompare(b, undefined, { numeric: true }));

const photos = entries.map(([, mod]) => imgUrl(mod));
const [heroSrc, ...gridSrcs] = photos;
---

<BaseLayout
	title="Galería — Manuel Parada"
	description="Galería de composición y animación con imágenes de muestra del portafolio."
>
	<SiteHeader />
	<main id="contenido" class="relative overflow-x-hidden">
		<section class="relative border-b border-white/10" aria-label="Cabecera de galería">
			<div class="ensayo-hero-vignette pointer-events-none absolute inset-0 z-10" />
			<div class="ensayo-hero-frame relative mx-auto max-h-[min(72vh,820px)] overflow-hidden">
				{
					heroSrc ? (
						<img
							src={heroSrc}
							alt=""
							class="ensayo-kenburns h-full w-full max-h-[min(72vh,820px)] object-cover object-center"
							width="1920"
							height="1080"
							decoding="async"
							fetchpriority="high"
						/>
					) : (
						<div class="flex h-64 items-center justify-center bg-neutral-900 text-neutral-500">
							Añade imágenes PNG en la carpeta Fotos
						</div>
					)
				}
			</div>
			<div class="relative z-20 mx-auto max-w-5xl px-4 py-10 sm:px-6">
				<p class="text-xs font-medium uppercase tracking-[0.2em] text-amber-200/80">Portafolio</p>
				<h1 class="mt-2 text-3xl font-light tracking-tight text-white sm:text-4xl">Galería</h1>
				<p class="mt-3 max-w-2xl text-sm leading-relaxed text-neutral-400">
					Composición, ritmo y microinteracciones con las fotos de prueba. Nada de aquí es definitivo: sirve para
					decidir qué sensación quieres para el sitio.
				</p>
			</div>
		</section>

		<section class="mx-auto max-w-6xl px-4 py-16 sm:px-6" aria-label="Cuadrícula de galería">
			<h2 class="sr-only">Galería de imágenes</h2>
			<ul class="ensayo-bento grid list-none gap-3 p-0 sm:gap-4 md:grid-cols-12">
				{
					gridSrcs.map((src, i) => (
						<li
							class:list={[
								'ensayo-card group relative overflow-hidden rounded-2xl border border-white/10 bg-neutral-900/40 shadow-[0_0_0_1px_rgba(255,255,255,0.04)]',
								i === 0 && 'md:col-span-7 md:row-span-2 min-h-[220px] sm:min-h-[280px]',
								i === 1 && 'md:col-span-5 min-h-[180px]',
								i === 2 && 'md:col-span-5 min-h-[180px]',
								i === 3 && 'md:col-span-4 min-h-[200px]',
								i === 4 && 'md:col-span-4 min-h-[200px]',
								i === 5 && 'md:col-span-4 min-h-[200px]',
								i >= 6 && 'md:col-span-12 min-h-[240px] max-h-[min(50vh,420px)]',
							]}
							style={{ '--ensayo-i': String(i) }}
						>
							<img
								src={src}
								alt=""
								class="ensayo-card-img absolute inset-0 h-full w-full object-cover transition-[transform,filter] duration-700 ease-out group-hover:scale-[1.04] group-hover:brightness-110"
								loading="lazy"
								decoding="async"
								width="1200"
								height="900"
							/>
							<div
								class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-80 transition-opacity duration-500 group-hover:opacity-95"
								aria-hidden="true"
							/>
							<span class="absolute bottom-4 left-4 z-10 font-mono text-[10px] uppercase tracking-widest text-white/70 transition-transform duration-500 group-hover:translate-y-[-2px]">
								Muestra {i + 2}
							</span>
						</li>
					))
				}
			</ul>
		</section>

		<section
			class="border-t border-white/10 bg-gradient-to-b from-neutral-950 to-neutral-900/80 px-4 py-14 sm:px-6"
			aria-label="Cinta de movimiento"
		>
			<div class="mx-auto max-w-5xl">
				<p class="text-xs font-medium uppercase tracking-[0.2em] text-neutral-500">Marquesina</p>
				<p class="mt-1 text-sm text-neutral-400">Mismo material en bucle suave — útil para cabeceras o pie de página.</p>
			</div>
			<div class="ensayo-marquee-wrap relative mt-8 overflow-hidden py-2">
				<div class="ensayo-marquee-fade pointer-events-none absolute inset-y-0 left-0 z-10 w-24 bg-gradient-to-r from-neutral-950 to-transparent sm:w-32" />
				<div class="ensayo-marquee-fade pointer-events-none absolute inset-y-0 right-0 z-10 w-24 bg-gradient-to-l from-neutral-950 to-transparent sm:w-32" />
				<div class="ensayo-marquee flex w-max gap-4">
					{
						[...photos, ...photos].map((src, idx) => (
							<img
								src={src}
								alt=""
								class="h-24 w-36 shrink-0 rounded-lg object-cover opacity-90 ring-1 ring-white/10 sm:h-28 sm:w-44"
								loading="lazy"
								decoding="async"
								width="176"
								height="112"
								data-marquee-idx={idx}
							/>
						))
					}
				</div>
			</div>
		</section>
	</main>
</BaseLayout>

<style>
	.ensayo-hero-vignette {
		box-shadow: inset 0 0 120px 40px rgb(10 10 10);
	}

	@media (prefers-reduced-motion: no-preference) {
		.ensayo-kenburns {
			animation: ensayo-kenburns 28s ease-in-out infinite alternate;
		}

		@keyframes ensayo-kenburns {
			0% {
				transform: scale(1) translate(0, 0);
			}
			100% {
				transform: scale(1.12) translate(-2%, -1%);
			}
		}

		.ensayo-card {
			opacity: 0;
			animation: ensayo-card-in 0.85s cubic-bezier(0.22, 1, 0.36, 1) forwards;
			animation-delay: calc(var(--ensayo-i, 0) * 0.07s);
		}

		@keyframes ensayo-card-in {
			from {
				opacity: 0;
				transform: translateY(28px) scale(0.98);
				filter: blur(6px);
			}
			to {
				opacity: 1;
				transform: translateY(0) scale(1);
				filter: blur(0);
			}
		}

	}

	/* Marquesina: fuera de no-preference (WebViews móviles a menudo no aplican esa media query). */
	@keyframes ensayo-marquee-scroll {
		from {
			transform: translate3d(0, 0, 0);
		}
		to {
			transform: translate3d(-50%, 0, 0);
		}
	}

	.ensayo-marquee {
		will-change: transform;
		-webkit-animation: ensayo-marquee-scroll 40s linear infinite;
		animation: ensayo-marquee-scroll 40s linear infinite;
	}

	@media (prefers-reduced-motion: reduce) {
		.ensayo-card {
			opacity: 1;
		}

		.ensayo-marquee {
			-webkit-animation: none !important;
			animation: none !important;
			will-change: auto;
		}
	}

	/* Pausa solo con puntero fino; en táctil :hover pegado frenaba la cinta. */
	@media (hover: hover) and (pointer: fine) {
		.ensayo-marquee-wrap:hover .ensayo-marquee {
			-webkit-animation-play-state: paused;
			animation-play-state: paused;
		}
	}

	@supports (animation-timeline: view()) {
		@media (prefers-reduced-motion: no-preference) {
			.ensayo-bento .ensayo-card {
				opacity: 0.15;
				transform: translateY(32px) scale(0.98);
				filter: blur(4px);
				animation: ensayo-card-view linear both;
				animation-timeline: view();
				animation-range: entry 0% entry 45%;
			}

			@keyframes ensayo-card-view {
				to {
					opacity: 1;
					transform: translateY(0) scale(1);
					filter: blur(0);
				}
			}
		}
	}
</style>
