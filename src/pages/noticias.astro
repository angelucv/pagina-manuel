---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import InstagramFeed from '../components/InstagramFeed.astro';
import { directorioNoticiasMedios } from '../data/biografia-enlaces';
import instagramPosts from '../data/instagram-posts.json';
import instagramWidget from '../data/instagram-widget.json';
import type { InstagramPost, InstagramWidgetConfig } from '../data/instagram-types';

const instagramProfileUrl = 'https://www.instagram.com/manuelparadaescultor/';
const posts = instagramPosts as InstagramPost[];
/** El embed de Elfsight vive en la página de inicio (src/data/instagram-widget-embed.html). */
const widget = instagramWidget as InstagramWidgetConfig;
---

<BaseLayout
	title="Noticias y medios — Manuel Parada"
	description="Prensa, instituciones y video sobre la obra pública de Manuel Parada."
>
	<SiteHeader />
	<main id="contenido" class="mx-auto max-w-3xl px-4 pb-20 pt-10 sm:px-6 sm:pt-12">
		<p class="text-sm text-neutral-500">
			<a href="/" class="text-amber-200/90 underline-offset-2 hover:underline">Inicio</a>
			<span class="mx-2 text-neutral-600">/</span>
			<span class="text-neutral-400">Noticias</span>
		</p>
		<h1 class="mt-4 text-3xl font-light tracking-tight text-white sm:text-4xl">Noticias y medios</h1>
		<p class="mt-4 text-sm leading-relaxed text-neutral-400">
			Enlaces a reportajes y documentos que respaldan la trayectoria. Abren en una nueva pestaña. El catálogo de obras
			está en <a href="/obra" class="text-amber-200/90 underline-offset-2 hover:underline">Obras</a>.
		</p>

		<ul class="mt-10 list-none space-y-5 border-l border-amber-200/20 pl-5">
			{
				directorioNoticiasMedios.map(({ titulo, href, fuente }) => (
					<li>
						<a
							href={href}
							class="text-base text-amber-200/90 underline-offset-2 hover:underline"
							target="_blank"
							rel="noopener noreferrer"
						>
							{titulo}
						</a>
						<span class="mt-1 block text-xs text-neutral-600">{fuente}</span>
					</li>
				))
			}
		</ul>

		<InstagramFeed posts={posts} profileUrl={instagramProfileUrl} widget={widget} />
	</main>
</BaseLayout>
