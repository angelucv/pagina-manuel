---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { categoriasObras } from '../../data/obras-catalogo';

const toc = categoriasObras.map((c) => ({ id: c.id, label: c.titulo }));
---

<BaseLayout
	title="Obras — Manuel Parada"
	description="Catálogo de esculturas públicas, arte sacro, monumentos y líneas de trabajo del taller Manuel Parada."
>
	<SiteHeader />
	<main id="contenido" class="mx-auto max-w-5xl px-4 pb-20 pt-10 sm:px-6 sm:pt-12">
		<p class="text-sm text-neutral-500">
			<a href="/" class="text-amber-200/90 underline-offset-2 hover:underline">Inicio</a>
			<span class="mx-2 text-neutral-600">/</span>
			<span class="text-neutral-400">Obras</span>
		</p>
		<h1 class="mt-4 text-3xl font-light tracking-tight text-white sm:text-4xl">Obras</h1>
		<p class="mt-4 max-w-2xl text-sm leading-relaxed text-neutral-400">
			Catálogo por ámbitos (fechas y sedes según documentación del sitio).
			<a href="/obra-en-venezuela" class="text-amber-200/90 underline-offset-2 hover:underline">Mapa interactivo</a>
			para ubicaciones. Contexto del artista:
			<a href="/sobre" class="text-amber-200/90 underline-offset-2 hover:underline">Sobre</a>
			· prensa:
			<a href="/noticias" class="text-amber-200/90 underline-offset-2 hover:underline">Noticias</a>.
		</p>

		<nav class="mt-10 border-y border-white/10 py-6" aria-label="Índice del catálogo">
			<p class="text-[10px] font-medium uppercase tracking-[0.25em] text-neutral-500">Saltar a sección</p>
			<ul class="mt-3 flex flex-wrap gap-x-3 gap-y-2 text-sm">
				{
					toc.map(({ id, label }) => (
						<li>
							<a
								href={`#${id}`}
								class="rounded-md px-2 py-1 text-neutral-400 transition-colors hover:bg-white/5 hover:text-white"
							>
								{label}
							</a>
						</li>
					))
				}
			</ul>
		</nav>

		<div class="mt-12 space-y-16">
			{
				categoriasObras.map((cat) => (
					<section id={cat.id} class="scroll-mt-28">
						<h2 class="text-xs font-medium uppercase tracking-[0.2em] text-amber-200/80">{cat.titulo}</h2>
						{cat.intro && <p class="mt-3 max-w-2xl text-sm leading-relaxed text-neutral-500">{cat.intro}</p>}
						<ul class="mt-6 list-none space-y-5 p-0">
							{cat.items.map((obra) => (
								<li
									class="rounded-xl border border-white/10 bg-neutral-900/30 px-4 py-4 sm:px-5 sm:py-5"
								>
									<div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
										<h3 class="text-base font-medium text-white">{obra.titulo}</h3>
										{obra.tipo && (
											<span class="text-xs text-neutral-500">· {obra.tipo}</span>
										)}
										{obra.año && (
											<span class="text-xs font-medium text-amber-200/70">{obra.año}</span>
										)}
									</div>
									<p class="mt-2 text-sm text-neutral-400">
										<span class="text-neutral-500">Ubicación / contexto:</span> {obra.lugar}
									</p>
									{obra.detalles && (
										<p class="mt-2 text-sm leading-relaxed text-neutral-500">{obra.detalles}</p>
									)}
								</li>
							))}
						</ul>
					</section>
				))
			}
		</div>
	</main>
</BaseLayout>
