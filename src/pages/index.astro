---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import HomeGalleryWall from '../components/HomeGalleryWall.astro';
const logosGaleria = [
	{ src: '/logo-marca-apilada.png', alt: 'Manuel Parada, escultor — logotipo principal' },
	{ src: '/logo-propuestas/logomanu1.PNG', alt: 'Propuesta de logotipo 1' },
	{ src: '/logo-propuestas/logomanu2.PNG', alt: 'Propuesta de logotipo 2' },
	{ src: '/logo-propuestas/logomanu3.PNG', alt: 'Propuesta de logotipo 3' },
] as const;
---

<BaseLayout
	title="Manuel Parada — escultor"
	description="Escultura como presencia: íntima o colosal. Encargos para particulares, colectivos e instituciones. Piedra, bronce, resina y fibra."
>
	<SiteHeader />
	<div class="relative isolate min-h-[calc(100dvh-11rem)] bg-neutral-950">
		<HomeGalleryWall />
		<main
			id="contenido"
			class="relative z-10 mx-auto max-w-5xl border-t border-white/10 px-4 py-12 sm:px-6 sm:py-14"
		>
			<section class="space-y-10" aria-labelledby="galeria-logos-titulo">
				<div class="max-w-3xl text-left">
					<h1 class="text-2xl font-light tracking-tight text-white sm:text-3xl">Manuel Parada</h1>
					<p class="mt-3 text-base leading-relaxed text-neutral-400 sm:text-lg">
						La escultura como presencia:
						<strong class="font-medium text-neutral-300">íntima o colosal</strong>, clásica o contemporánea. Manuel
						Parada moldea ese espectro para
						<strong class="font-medium text-neutral-300">particulares, colectivos e instituciones</strong>, y para el
						<strong class="font-medium text-neutral-300">espacio público</strong> que todos habitan.
						<strong class="font-medium text-neutral-300">Piedra, bronce, resina y fibra</strong>; entornos que van del
						<strong class="font-medium text-neutral-300">rincón devocional al paisaje urbano</strong> — siempre con una
						lectura plástica clara y un oficio que responde al lugar.
					</p>
					<p class="mt-5 flex flex-wrap gap-x-4 gap-y-2 text-sm">
						<a
							href="/sobre"
							class="font-medium text-amber-200/90 underline-offset-2 transition-colors hover:text-amber-100 hover:underline"
							>Sobre</a
						>
						<span class="text-neutral-600" aria-hidden="true">·</span>
						<a
							href="/obra"
							class="font-medium text-amber-200/90 underline-offset-2 transition-colors hover:text-amber-100 hover:underline"
							>Obras</a
						>
						<span class="text-neutral-600" aria-hidden="true">·</span>
						<a
							href="/obra-en-venezuela"
							class="font-medium text-amber-200/90 underline-offset-2 transition-colors hover:text-amber-100 hover:underline"
							>Mapa</a
						>
						<span class="text-neutral-600" aria-hidden="true">·</span>
						<a
							href="/noticias"
							class="font-medium text-amber-200/90 underline-offset-2 transition-colors hover:text-amber-100 hover:underline"
							>Noticias</a
						>
					</p>
				</div>

				<div>
					<h2
						id="galeria-logos-titulo"
						class="text-[10px] font-medium uppercase tracking-[0.25em] text-neutral-500 sm:text-xs"
					>
						Galería de logos
					</h2>
					<ul class="mt-6 grid list-none grid-cols-2 gap-4 p-0 sm:gap-5 lg:grid-cols-4">
						{
							logosGaleria.map(({ src, alt }, i) => (
								<li>
									<figure
										class="flex h-full min-h-[140px] flex-col overflow-hidden rounded-xl border border-white/10 bg-neutral-900/40 p-4 shadow-[inset_0_1px_0_rgb(255_255_255/0.04)] sm:min-h-[160px] sm:p-5"
									>
										<img
											src={src}
											alt={alt}
											width="1024"
											height="571"
											class="mx-auto h-full max-h-36 w-full max-w-full object-contain object-center sm:max-h-44"
											loading={i === 0 ? 'eager' : 'lazy'}
											decoding="async"
											fetchpriority={i === 0 ? 'high' : undefined}
										/>
									</figure>
								</li>
							))
						}
					</ul>
				</div>
			</section>
		</main>
	</div>
</BaseLayout>
