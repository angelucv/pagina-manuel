---
/**
 * Réplica del bloque tipográfico (MANUEL / Parada / ESCULTOR) con MANUEL y ESCULTOR más grandes.
 * Solo revisión — noindex. Abre /logo-replica con el dev server.
 */
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="robots" content="noindex, nofollow" />
		<title>Réplica logo — MANUEL · Parada · ESCULTOR</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@500;600;700&family=Permanent+Marker&display=swap"
			rel="stylesheet"
		/>
		<style is:global>
			html,
			body {
				background-color: #000000 !important;
				color: #f2ebe3;
			}
		</style>
	</head>
	<body class="flex min-h-dvh items-center justify-center antialiased">
		<div class="flex flex-col items-center gap-4 px-6 text-center sm:gap-5">
			<p
				class="text-[clamp(1.35rem,4.6vw,2.125rem)] font-bold uppercase tracking-[0.36em] text-[#f2ebe3]"
				style="font-family: 'DM Sans', system-ui, sans-serif;"
			>
				MANUEL
			</p>
			<p
				class="text-[clamp(3.5rem,14vw,6.75rem)] leading-none text-[#f2ebe3]"
				style="font-family: 'Permanent Marker', cursive; letter-spacing: 0.04em;"
			>
				Parada
			</p>
			<p
				class="text-[clamp(1.25rem,4.2vw,2rem)] font-bold uppercase tracking-[0.3em] text-[#f2ebe3]"
				style="font-family: 'DM Sans', system-ui, sans-serif;"
			>
				ESCULTOR
			</p>
		</div>
		<p class="fixed bottom-4 left-0 right-0 text-center text-xs text-neutral-500">
			<a href="/" class="text-neutral-400 underline-offset-2 hover:underline">Inicio</a>
			· réplica HTML (ajusta <code class="text-neutral-400">clamp</code> si hace falta)
		</p>
	</body>
</html>
