---
/**
 * Marca diamante (MANUEL · Parada · ESCULTOR) en SVG inline.
 * Vector nítido a cualquier tamaño; tipografía acorde al sitio (Cormorant + sans del sistema).
 */
interface Props {
	class?: string;
}

const { class: className = '' } = Astro.props;
---

<span class:list={['inline-block aspect-square overflow-hidden rounded-lg ring-1 ring-white/[0.06]', className]}>
	<svg
		class="block h-full w-full"
		viewBox="0 0 512 512"
		width="512"
		height="512"
		xmlns="http://www.w3.org/2000/svg"
		aria-hidden="true"
		focusable="false"
	>
		<defs>
			<radialGradient id="mp-logo-bg" cx="50%" cy="50%" r="68%" fx="50%" fy="50%">
				<stop offset="0%" style="stop-color: #262626" />
				<stop offset="55%" style="stop-color: #141414" />
				<stop offset="100%" style="stop-color: #0a0a0a" />
			</radialGradient>
		</defs>
		<!-- Fondo cuadrado con ligera profundidad (se integra en header oscuro) -->
		<rect width="512" height="512" fill="url(#mp-logo-bg)" />
		<!-- Rombo principal -->
		<polygon
			points="256,88 416,256 256,424 96,256"
			fill="#050505"
			stroke="#f5f5f5"
			stroke-width="2.25"
			stroke-linejoin="miter"></polygon>
		<!-- Tipografía centrada en el rombo -->
		<text
			x="256"
			y="186"
			text-anchor="middle"
			fill="#a3a3a3"
			style="font-family: ui-sans-serif, system-ui, sans-serif; font-size: 21px; font-weight: 600; letter-spacing: 0.38em;"
		>
			MANUEL
		</text>
		<text
			x="256"
			y="278"
			text-anchor="middle"
			fill="#fafafa"
			style="font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif; font-size: 86px; font-weight: 700; letter-spacing: 0.02em;"
		>
			Parada
		</text>
		<text
			x="256"
			y="352"
			text-anchor="middle"
			fill="#a3a3a3"
			style="font-family: ui-sans-serif, system-ui, sans-serif; font-size: 19px; font-weight: 600; letter-spacing: 0.32em;"
		>
			ESCULTOR
		</text>
	</svg>
</span>
