---
/**
 * Logo construido: MANUEL / Parada (Cormorant) / ESCULTOR (DM Sans).
 */
interface Props {
	class?: string;
}

const { class: className = '' } = Astro.props;
---

<span class:list={['flex min-w-0 flex-col justify-center leading-[1.05]', className]}>
	<span
		class="font-mp-marca-sans text-lg font-semibold uppercase tracking-[0.16em] text-neutral-500 sm:text-xl md:text-2xl lg:text-3xl"
	>
		Manuel
	</span>
	<span
		class="font-logo-parada text-3xl font-bold tracking-[0.02em] text-white sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl"
	>
		Parada
	</span>
	<span
		class="font-mp-marca-sans mt-1 text-base font-medium uppercase tracking-[0.14em] text-neutral-500 sm:text-lg md:text-xl lg:text-2xl"
	>
		Escultor
	</span>
</span>
