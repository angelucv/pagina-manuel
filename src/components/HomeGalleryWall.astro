---
/**
 * Propuesta A: muro de obra con foco al hover (puntero fino) o al toque (táctil).
 */
type GlobImg = string | { src: string };

function imgUrl(m: GlobImg): string {
	return typeof m === 'string' ? m : m.src;
}

const modules = import.meta.glob<GlobImg>('../../Fotos/*.png', { eager: true, import: 'default' });
const entries = Object.entries(modules).sort(([a], [b]) => a.localeCompare(b, undefined, { numeric: true }));
const photos = entries.map(([, mod]) => imgUrl(mod));

function pairForCell(i: number, n: number): { a: string; b: string } {
	const a = photos[i] ?? '';
	const b = photos[(i + 3) % n] ?? a;
	return { a, b };
}

/** Menos de 8 piezas: el mosaico fijo asigna celdas grandes a índices inexistentes → rejilla uniforme. */
const photoCount = photos.length;
const useUniformWall = photoCount > 0 && photoCount < 8;

function uniformWallCols(n: number, breakpoint: 'sm' | 'md'): number {
	if (n <= 1) return 1;
	if (breakpoint === 'sm') return 2;
	if (n === 2) return 2;
	if (n === 3) return 3;
	if (n === 4) return 2;
	return 3;
}
---

{
	photos.length > 0 && (
		<section
			class="home-wall-section relative w-full"
			aria-label="Selección de obra"
			id="home-wall-section"
		>
			<div class="home-wall-shell mx-auto w-full max-w-xl px-3 pt-4 sm:max-w-2xl sm:px-4 md:max-w-4xl md:px-6 md:pt-6 lg:max-w-5xl xl:max-w-6xl">
				<p class="mb-4 text-center text-[10px] font-medium uppercase tracking-[0.25em] text-neutral-500 sm:text-left sm:text-xs">
					Obra — muestras
					{
						photos.length >= 2 && (
							<span class="mt-2 block max-w-prose font-normal normal-case leading-relaxed tracking-normal text-neutral-500">
								Fotos sujetas con chincheta sobre corcho; cada pieza alterna dos vistas (en móvil el cambio es un poco
								más ágil). Cada 6 s hay un pulso en el tablero; con 8 o más fotos el mosaico también cambia de
								disposición. Si tu teléfono tiene «reducir movimiento» activado, las animaciones se respetan y se
								apagan.
							</span>
						)
					}
				</p>
				<div class="home-wall px-0 py-1 sm:px-0 sm:py-2 md:py-3" data-home-wall>
					<div class="home-wall-cork-board" data-cork-board>
						<span class="home-wall-ambient-pulse" aria-hidden="true" />
						<div
							class:list={['home-wall-grid', 'home-wall-grid--atelier', useUniformWall && 'home-wall-grid--uniform']}
							data-mosaic-layout="0"
							data-mosaic-root
							data-photo-count={photoCount}
							style={
								useUniformWall
									? {
											'--wall-uniform-cols-sm': String(uniformWallCols(photoCount, 'sm')),
											'--wall-uniform-cols-md': String(uniformWallCols(photoCount, 'md')),
										}
									: undefined
							}
						>
						{photos.map((src, i) => {
							const n = photos.length;
							const { a, b } = pairForCell(i, n);
							const dual = n >= 2;
							return (
								<button
									type="button"
									class:list={['home-wall-tile', `home-wall-tile--${i}`]}
									style={{
										'--breathe': i,
										'--place-sign': i % 2 === 0 ? 1 : -1,
									}}
									aria-pressed="false"
									aria-label={`Ampliar vista de la muestra ${i + 1}`}
								>
									<span class="home-wall-breathe" aria-hidden="true">
										{dual ? (
											<span class="home-wall-crossfade">
												<img
													src={a}
													alt=""
													loading={i < 2 ? 'eager' : 'lazy'}
													decoding="async"
													width="900"
													height="700"
													class="home-wall-layer home-wall-layer--a"
													draggable="false"
												/>
												<img
													src={b}
													alt=""
													loading="lazy"
													decoding="async"
													width="900"
													height="700"
													class="home-wall-layer home-wall-layer--b"
													draggable="false"
												/>
											</span>
										) : (
											<img
												src={src}
												alt=""
												loading="eager"
												decoding="async"
												width="900"
												height="700"
												class="home-wall-img home-wall-img--single"
												draggable="false"
											/>
										)}
									</span>
								</button>
							);
						})}
						</div>
					</div>
				</div>
				<p class="mt-3 text-center text-[11px] text-neutral-500 sm:text-left">
					<span class="hidden sm:inline">Pasa el cursor sobre una pieza para enfocarla.</span>
					<span class="sm:hidden">Toca una pieza para enfocarla; toca fuera para restablecer.</span>
				</p>
			</div>
		</section>
	)
}

<script>
	function initHomeWall() {
		const root = document.getElementById('home-wall-section');
		const wall = root?.querySelector('[data-home-wall]');
		if (!root || !wall || root.dataset.wallTouchBound === '1') return;

		if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
			root.dataset.wallTouchBound = '1';
			return;
		}

		root.dataset.wallTouchBound = '1';

		root.addEventListener('click', (e) => {
			const t = e.target.closest('.home-wall-tile');
			if (t && wall.contains(t)) {
				const on = t.getAttribute('aria-pressed') === 'true';
				wall.querySelectorAll('.home-wall-tile').forEach((b) => b.setAttribute('aria-pressed', 'false'));
				if (!on) t.setAttribute('aria-pressed', 'true');
				return;
			}
			wall.querySelectorAll('.home-wall-tile').forEach((b) => b.setAttribute('aria-pressed', 'false'));
		});
	}

	document.addEventListener('astro:page-load', initHomeWall);
	document.addEventListener('DOMContentLoaded', initHomeWall);
	initHomeWall();

	const MOSAIC_MS = 6000;
	const MOSAIC_COUNT = 3;
	/** Un solo intervalo global: evita fugas al usar View Transitions y al volver al inicio. */
	let mosaicIntervalId = 0;

	function clearMosaicInterval() {
		if (mosaicIntervalId) {
			window.clearInterval(mosaicIntervalId);
			mosaicIntervalId = 0;
		}
	}

	function initMosaicRotate() {
		clearMosaicInterval();

		const grid = document.querySelector<HTMLElement>('[data-mosaic-root]');
		if (!grid) return;

		const photoCount = Number(grid.dataset.photoCount || '0');
		if (photoCount < 8) {
			grid.dataset.mosaicLayout = '0';
		}

		const tick = () => {
			const g = document.querySelector<HTMLElement>('[data-mosaic-root]');
			if (!g) return;
			const n = Number(g.dataset.photoCount || '0');
			if (n >= 8) {
				const cur = Number(g.dataset.mosaicLayout || 0);
				g.dataset.mosaicLayout = String((cur + 1) % MOSAIC_COUNT);
			}
			const board = g.closest('[data-cork-board]');
			if (board instanceof HTMLElement && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
				board.classList.add('home-wall-cork-board--repin');
				window.setTimeout(() => board.classList.remove('home-wall-cork-board--repin'), 420);
			}
		};

		const arm = () => {
			clearMosaicInterval();
			const g = document.querySelector<HTMLElement>('[data-mosaic-root]');
			if (!g) return;
			if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
				g.dataset.mosaicLayout = '0';
				return;
			}
			mosaicIntervalId = window.setInterval(tick, MOSAIC_MS);
		};

		arm();
	}

	const w = window as Window & { __mpMosaicPrm?: boolean };
	if (!w.__mpMosaicPrm) {
		w.__mpMosaicPrm = true;
		window.matchMedia('(prefers-reduced-motion: reduce)').addEventListener('change', initMosaicRotate);
	}

	function scheduleMosaicInit() {
		requestAnimationFrame(() => {
			requestAnimationFrame(initMosaicRotate);
		});
	}

	document.addEventListener('astro:page-load', scheduleMosaicInit);
	document.addEventListener('DOMContentLoaded', scheduleMosaicInit);
	scheduleMosaicInit();
</script>

<style>
	.home-wall-grid {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.home-wall-grid--atelier {
		padding-block: 0.35rem 0.6rem;
	}

	/* Pocas fotos: misma escala en todas las celdas (el mosaico de 8 asume 8 piezas). */
	.home-wall-grid.home-wall-grid--uniform {
		grid-template-columns: repeat(var(--wall-uniform-cols-sm, 2), minmax(0, 1fr));
	}

	/* Tablero de corcho + marco de madera (procedural, sin imagen externa) */
	.home-wall-cork-board {
		position: relative;
		margin-inline: auto;
		max-width: 100%;
		border-radius: 8px;
		padding: 1rem 0.75rem 1.2rem;
		border: 7px solid;
		border-color: #5c4030 #2e1f15 #4a3325 #3d2818;
		box-shadow:
			inset 0 0 0 1px rgb(0 0 0 / 0.4),
			inset 0 1px 0 rgb(255 255 255 / 0.07),
			inset 0 -24px 60px rgb(0 0 0 / 0.2),
			0 18px 42px rgb(0 0 0 / 0.55);
		background-color: #654a38;
		background-image:
			radial-gradient(ellipse 90% 70% at 20% 25%, rgb(255 255 255 / 0.1) 0%, transparent 45%),
			radial-gradient(ellipse 60% 50% at 85% 80%, rgb(0 0 0 / 0.14) 0%, transparent 48%),
			radial-gradient(circle at 30% 70%, rgb(0 0 0 / 0.07) 0 2px, transparent 3px),
			radial-gradient(circle at 75% 28%, rgb(255 255 255 / 0.04) 0 1px, transparent 2px),
			repeating-linear-gradient(
				88deg,
				transparent 0,
				transparent 13px,
				rgb(0 0 0 / 0.035) 13px,
				rgb(0 0 0 / 0.035) 14px
			),
			repeating-linear-gradient(
				3deg,
				transparent 0,
				transparent 17px,
				rgb(255 255 255 / 0.018) 17px,
				rgb(255 255 255 / 0.018) 18px
			),
			linear-gradient(168deg, #7d5c47 0%, #5a4233 42%, #6e5240 100%);
		transition: filter 0.55s ease, box-shadow 0.55s ease;
	}

	/* Brillo suave en móvil (CSS puro; no depende solo del JS del intervalo). */
	.home-wall-ambient-pulse {
		position: absolute;
		inset: 14px 12px 18px;
		border-radius: 4px;
		pointer-events: none;
		z-index: 0;
		display: block;
		opacity: 0;
	}

	@keyframes mp-wall-ambient {
		0%,
		86%,
		100% {
			opacity: 0;
		}
		88%,
		92% {
			opacity: 1;
		}
	}

	@media (max-width: 767.98px) {
		@media (prefers-reduced-motion: no-preference) {
			.home-wall-ambient-pulse {
				background: radial-gradient(
					ellipse 85% 75% at 50% 42%,
					rgb(255 255 255 / 0.2),
					transparent 62%
				);
				animation: mp-wall-ambient 6s ease-in-out infinite;
			}
		}
	}

	/* Al enfocar una foto el corcho se oscurece un poco (contraste con la pieza activa). */
	.home-wall-cork-board--repin {
		filter: brightness(1.08) saturate(1.1) !important;
		transition: filter 0.22s ease;
	}

	@media (hover: hover) and (pointer: fine) {
		.home-wall:has(.home-wall-tile:hover) .home-wall-cork-board {
			filter: brightness(0.9) saturate(0.92);
			box-shadow:
				inset 0 0 0 1px rgb(0 0 0 / 0.45),
				inset 0 1px 0 rgb(255 255 255 / 0.05),
				inset 0 -24px 60px rgb(0 0 0 / 0.28),
				0 14px 36px rgb(0 0 0 / 0.6);
		}
	}

	.home-wall:has(.home-wall-tile[aria-pressed='true']) .home-wall-cork-board {
		filter: brightness(0.9) saturate(0.92);
		box-shadow:
			inset 0 0 0 1px rgb(0 0 0 / 0.45),
			inset 0 1px 0 rgb(255 255 255 / 0.05),
			inset 0 -24px 60px rgb(0 0 0 / 0.28),
			0 14px 36px rgb(0 0 0 / 0.6);
	}

	.home-wall-tile {
		position: relative;
		overflow: visible;
		border: none;
		border-radius: 0;
		padding: 0;
		padding-top: 10px;
		margin: 0;
		background: transparent;
		cursor: pointer;
		-webkit-tap-highlight-color: transparent;
		transition:
			opacity 0.45s ease,
			filter 0.45s ease,
			transform 0.45s ease;
	}

	/* Aguja de chincheta (detrás de la cabeza) */
	.home-wall-tile::before {
		content: '';
		position: absolute;
		top: 10px;
		left: calc(50% + var(--breathe) * 1px - 3.5px);
		z-index: 4;
		width: 2px;
		height: 15px;
		margin-left: -1px;
		border-radius: 1px;
		background: linear-gradient(180deg, #e2e8f0, #64748b 45%, #334155);
		box-shadow: 1px 2px 3px rgb(0 0 0 / 0.35);
		pointer-events: none;
	}

	/* Cabeza de chincheta */
	.home-wall-tile::after {
		content: '';
		position: absolute;
		top: 2px;
		left: calc(50% + var(--breathe) * 1px - 3.5px);
		z-index: 6;
		width: 12px;
		height: 12px;
		margin-left: -6px;
		border-radius: 50%;
		background: radial-gradient(
			circle at 32% 28%,
			rgb(254 226 226),
			rgb(220 38 38) 52%,
			rgb(127 29 29)
		);
		box-shadow:
			0 2px 4px rgb(0 0 0 / 0.45),
			inset 0 1px 1px rgb(255 255 255 / 0.5);
		pointer-events: none;
		transform: rotate(calc(var(--place-sign, 1) * 9deg));
	}

	.home-wall-breathe {
		display: block;
		width: 100%;
		height: auto;
	}

	/* Dos capas en la misma celda: la fila toma la altura máxima de las dos fotos (sin recuadro). */
	.home-wall-crossfade {
		display: grid;
		grid-template-columns: minmax(0, 1fr);
		width: 100%;
		height: auto;
		transform: scale(1);
		filter: drop-shadow(0 6px 14px rgb(0 0 0 / 0.45)) drop-shadow(0 1px 2px rgb(0 0 0 / 0.35));
		transition:
			transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
			filter 0.45s ease;
	}

	.home-wall-layer {
		grid-column: 1;
		grid-row: 1;
		display: block;
		width: 100%;
		max-width: 100%;
		height: auto;
	}

	.home-wall-img--single {
		display: block;
		width: 100%;
		max-width: 100%;
		height: auto;
		transform: scale(1);
		filter: drop-shadow(0 6px 14px rgb(0 0 0 / 0.45)) drop-shadow(0 1px 2px rgb(0 0 0 / 0.35));
		transition:
			transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
			filter 0.45s ease;
	}

	.home-wall-tile--0 {
		transform: translate(3px, 4px) rotate(-1.1deg);
	}
	.home-wall-tile--1 {
		transform: translate(-2px, 10px) rotate(1deg);
	}
	.home-wall-tile--2 {
		transform: translate(4px, 6px) rotate(-0.9deg);
	}
	.home-wall-tile--3 {
		transform: translate(-4px, -2px) rotate(0.85deg);
	}
	.home-wall-tile--4 {
		transform: translate(2px, 12px) rotate(-0.75deg);
	}
	.home-wall-tile--5 {
		transform: translate(-3px, 4px) rotate(1.05deg);
	}
	.home-wall-tile--6 {
		transform: translate(5px, 8px) rotate(0.65deg);
	}
	.home-wall-tile--7 {
		transform: translate(-2px, -4px) rotate(-0.95deg);
	}

	/* Móvil: tres disposiciones del mosaico (misma lógica que desktop; solo ≥8 fotos y sin rejilla uniforme). */
	@media (max-width: 767.98px) {
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='0'] .home-wall-tile--0,
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='0'] .home-wall-tile--1,
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='0'] .home-wall-tile--2,
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='0'] .home-wall-tile--3,
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='0'] .home-wall-tile--4,
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='0'] .home-wall-tile--5,
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='0'] .home-wall-tile--6,
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='0'] .home-wall-tile--7 {
			grid-column: auto;
			grid-row: auto;
		}

		/* Layout 1: franja ancha arriba y abajo */
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='1'] .home-wall-tile--0 {
			grid-column: 1 / -1;
			grid-row: 1;
		}
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='1'] .home-wall-tile--1 {
			grid-column: 1;
			grid-row: 2;
		}
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='1'] .home-wall-tile--2 {
			grid-column: 2;
			grid-row: 2;
		}
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='1'] .home-wall-tile--3 {
			grid-column: 1;
			grid-row: 3;
		}
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='1'] .home-wall-tile--4 {
			grid-column: 2;
			grid-row: 3;
		}
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='1'] .home-wall-tile--5 {
			grid-column: 1;
			grid-row: 4;
		}
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='1'] .home-wall-tile--6 {
			grid-column: 2;
			grid-row: 4;
		}
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='1'] .home-wall-tile--7 {
			grid-column: 1 / -1;
			grid-row: 5;
		}

		/* Layout 2: franjas anchas intercaladas */
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='2'] .home-wall-tile--0 {
			grid-column: 1;
			grid-row: 1;
		}
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='2'] .home-wall-tile--1 {
			grid-column: 2;
			grid-row: 1;
		}
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='2'] .home-wall-tile--2 {
			grid-column: 1 / -1;
			grid-row: 2;
		}
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='2'] .home-wall-tile--3 {
			grid-column: 1;
			grid-row: 3;
		}
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='2'] .home-wall-tile--4 {
			grid-column: 2;
			grid-row: 3;
		}
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='2'] .home-wall-tile--5 {
			grid-column: 1 / -1;
			grid-row: 4;
		}
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='2'] .home-wall-tile--6 {
			grid-column: 1;
			grid-row: 5;
		}
		.home-wall-grid:not(.home-wall-grid--uniform)[data-mosaic-layout='2'] .home-wall-tile--7 {
			grid-column: 2;
			grid-row: 5;
		}
	}

	@media (min-width: 768px) {
		.home-wall-grid {
			grid-template-columns: repeat(12, minmax(0, 1fr));
			grid-template-rows: repeat(4, auto);
			align-items: start;
			gap: 1.35rem;
		}

		.home-wall-tile--0,
		.home-wall-tile--1,
		.home-wall-tile--2,
		.home-wall-tile--3,
		.home-wall-tile--4,
		.home-wall-tile--5,
		.home-wall-tile--6,
		.home-wall-tile--7 {
			aspect-ratio: auto;
			min-height: 0;
		}

		/* Mosaico 0 — tres + tres + dos (nada de “hero” a media tabla) */
		.home-wall-grid[data-mosaic-layout='0'] .home-wall-tile--0 {
			grid-column: 1 / 5;
			grid-row: 1 / 2;
			min-height: 0;
			transform: translate(5px, 12px) rotate(-1.25deg);
		}
		.home-wall-grid[data-mosaic-layout='0'] .home-wall-tile--1 {
			grid-column: 5 / 9;
			grid-row: 1 / 2;
			min-height: 0;
			transform: translate(-5px, 22px) rotate(1.1deg);
		}
		.home-wall-grid[data-mosaic-layout='0'] .home-wall-tile--2 {
			grid-column: 9 / 13;
			grid-row: 1 / 2;
			min-height: 0;
			transform: translate(4px, 12px) rotate(-1deg);
		}
		.home-wall-grid[data-mosaic-layout='0'] .home-wall-tile--3 {
			grid-column: 1 / 5;
			grid-row: 2 / 3;
			min-height: 0;
			transform: translate(-5px, -10px) rotate(0.95deg);
		}
		.home-wall-grid[data-mosaic-layout='0'] .home-wall-tile--4 {
			grid-column: 5 / 9;
			grid-row: 2 / 3;
			min-height: 0;
			transform: translate(4px, 14px) rotate(-0.75deg);
		}
		.home-wall-grid[data-mosaic-layout='0'] .home-wall-tile--5 {
			grid-column: 9 / 13;
			grid-row: 2 / 3;
			min-height: 0;
			transform: translate(-4px, -4px) rotate(1.05deg);
		}
		.home-wall-grid[data-mosaic-layout='0'] .home-wall-tile--6 {
			grid-column: 1 / 7;
			grid-row: 3 / 4;
			min-height: 0;
