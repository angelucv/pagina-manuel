---
import LogoMarcaApilada from './LogoMarcaApilada.astro';

const links = [
	{ href: '/', label: 'Inicio' },
	{ href: '/sobre', label: 'Sobre' },
	{ href: '/galeria', label: 'Galería' },
	{ href: '/obra', label: 'Obras' },
	{ href: '/obra-en-venezuela', label: 'Mapa interactivo' },
	{ href: '/noticias', label: 'Noticias' },
] as const;

const navLinks = links;

/** Actualiza la URL de Facebook si la página oficial es otra. */
const social = {
	instagram: 'https://www.instagram.com/manuelparadaescultor/',
	facebook: 'https://www.facebook.com/manuelparadaescultor',
} as const;
---

<header class="border-b border-white/10 bg-neutral-950/80 backdrop-blur-md">
	<div
		class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-x-3 gap-y-2 px-4 py-3 sm:px-6 sm:py-4 md:gap-4 lg:max-w-7xl"
	>
		<a
			href="/"
			class="flex min-w-0 shrink-0 items-center transition-opacity hover:opacity-90"
			aria-label="Manuel Parada, escultor — inicio"
		>
			<LogoMarcaApilada />
		</a>
		<div class="flex min-w-0 flex-1 flex-wrap items-center justify-end gap-x-1 gap-y-2 sm:gap-x-2">
			<nav aria-label="Principal">
				<ul class="flex flex-wrap items-center justify-end gap-1 sm:gap-2 md:gap-4">
					{
						navLinks.map(({ href, label }) => (
							<li>
								<a
									href={href}
									class="rounded-md px-2.5 py-2 text-xs text-neutral-400 transition-colors hover:bg-white/5 hover:text-white sm:px-3 sm:text-sm lg:text-base"
								>
									{label}
								</a>
							</li>
						))
					}
					<li class="flex items-center gap-0.5 sm:gap-1" aria-label="Redes y contacto">
						<a
							href={social.instagram}
							target="_blank"
							rel="noopener noreferrer"
							class="rounded-md p-2 text-neutral-400 transition-colors hover:bg-white/5 hover:text-amber-200/95"
							aria-label="Instagram — @manuelparadaescultor"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="20"
								height="20"
								viewBox="0 0 24 24"
								fill="none"
								stroke="currentColor"
								stroke-width="1.75"
								stroke-linecap="round"
								stroke-linejoin="round"
								class="block"
								aria-hidden="true"
							>
								<rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
								<path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
								<line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
							</svg>
						</a>
						<a
							href={social.facebook}
							target="_blank"
							rel="noopener noreferrer"
							class="rounded-md p-2 text-neutral-400 transition-colors hover:bg-white/5 hover:text-amber-200/95"
							aria-label="Facebook — Manuel Parada"
						>
							<svg
								xmlns="http://www.w3.org/2000/svg"
								width="20"
								height="20"
								viewBox="0 0 24 24"
								fill="currentColor"
								class="block"
								aria-hidden="true"
							>
								<path
									d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
								></path>
							</svg>
						</a>
						<a
							href="/contacto"
							class="rounded-md px-2.5 py-2 text-xs text-neutral-400 transition-colors hover:bg-white/5 hover:text-white sm:px-3 sm:text-sm lg:text-base"
						>
							Contacto
						</a>
					</li>
				</ul>
			</nav>
		</div>
	</div>
</header>
