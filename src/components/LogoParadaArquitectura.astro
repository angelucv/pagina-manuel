---
/**
 * Marca tipo «facetas / diamante»: esquinas low-poly, MANUEL · PARADA · ESCULTOR.
 * `raster`: PNG en /public (fiel a la referencia). `vector`: SVG aproximado, nítido a cualquier tamaño.
 */
interface Props {
	class?: string;
	decorative?: boolean;
	variant?: 'raster' | 'vector';
	alt?: string;
}

const {
	class: className = '',
	decorative = false,
	variant = 'raster',
	alt = 'Manuel Parada, escultor',
} = Astro.props;
---

{
	variant === 'raster' ? (
		<img
			src="/logo-manuel-parada-faceted.png"
			alt={decorative ? '' : alt}
			width="1024"
			height="1024"
			class:list={['h-full w-full object-cover', className]}
			loading="eager"
			decoding="async"
			draggable="false"
			aria-hidden={decorative ? 'true' : undefined}
		/>
	) : (
		<span class:list={['inline-block', className]} aria-hidden={decorative ? 'true' : undefined}>
			<svg
				class="logo-arq-svg h-full w-full"
				viewBox="0 0 240 240"
				xmlns="http://www.w3.org/2000/svg"
				role={decorative ? undefined : 'img'}
				aria-label={decorative ? undefined : alt}
			>
				<title>{alt}</title>
				<defs>
					<linearGradient id="arq-tl1" x1="0" y1="0" x2="1" y2="1">
						<stop offset="0%" stop-color="#4a4a4a" />
						<stop offset="55%" stop-color="#2a2a2a" />
						<stop offset="100%" stop-color="#141414" />
					</linearGradient>
					<linearGradient id="arq-tl2" x1="0" y1="0" x2="0" y2="1">
						<stop offset="0%" stop-color="#5c5c5c" />
						<stop offset="100%" stop-color="#252525" />
					</linearGradient>
					<linearGradient id="arq-tr1" x1="1" y1="0" x2="0" y2="1">
						<stop offset="0%" stop-color="#4a4a4a" />
						<stop offset="100%" stop-color="#181818" />
					</linearGradient>
					<linearGradient id="arq-tr2" x1="1" y1="0" x2="0" y2="0">
						<stop offset="0%" stop-color="#555" />
						<stop offset="100%" stop-color="#222" />
					</linearGradient>
					<linearGradient id="arq-bl1" x1="0" y1="1" x2="1" y2="0">
						<stop offset="0%" stop-color="#454545" />
						<stop offset="100%" stop-color="#161616" />
					</linearGradient>
					<linearGradient id="arq-bl2" x1="0" y1="1" x2="0" y2="0">
						<stop offset="0%" stop-color="#505050" />
						<stop offset="100%" stop-color="#1c1c1c" />
					</linearGradient>
					<linearGradient id="arq-br1" x1="1" y1="1" x2="0" y2="0">
						<stop offset="0%" stop-color="#484848" />
						<stop offset="100%" stop-color="#121212" />
					</linearGradient>
					<linearGradient id="arq-br2" x1="1" y1="1" x2="1" y2="0">
						<stop offset="0%" stop-color="#535353" />
						<stop offset="100%" stop-color="#202020" />
					</linearGradient>
				</defs>
				<rect width="240" height="240" fill="#000" />
				<!-- Esquina SO: facetas hacia el centro -->
				<path d="M0 0 L118 0 L0 118 Z" fill="url(#arq-tl1)" />
				<path d="M0 0 L72 0 L0 72 Z" fill="url(#arq-tl2)" />
				<path d="M0 0 L52 0 L0 52 Z" fill="#3a3a3a" opacity="0.9" />
				<!-- Esquina SE -->
				<path d="M240 0 L122 0 L240 118 Z" fill="url(#arq-tr1)" />
				<path d="M240 0 L240 72 L168 0 Z" fill="url(#arq-tr2)" />
				<path d="M240 0 L240 52 L188 0 Z" fill="#353535" opacity="0.92" />
				<!-- Esquina NO -->
				<path d="M0 240 L118 240 L0 122 Z" fill="url(#arq-bl1)" />
				<path d="M0 240 L0 168 L72 240 Z" fill="url(#arq-bl2)" />
				<path d="M0 240 L0 188 L52 240 Z" fill="#383838" opacity="0.9" />
				<!-- Esquina NE -->
				<path d="M240 240 L122 240 L240 122 Z" fill="url(#arq-br1)" />
				<path d="M240 240 L168 240 L240 168 Z" fill="url(#arq-br2)" />
				<path d="M240 240 L188 240 L240 188 Z" fill="#323232" opacity="0.92" />
				<!-- Brillo esquina inferior derecha -->
				<path
					d="M228 228 L232 220 L236 228 L232 232 Z"
					fill="#9ca3af"
					opacity="0.55"
				/>
				<style>
					.logo-arq-svg .arq-sans {
						font-family: ui-sans-serif, system-ui, sans-serif;
						font-weight: 500;
						font-size: 9px;
						letter-spacing: 0.38em;
						text-anchor: middle;
						fill: #737373;
					}
					.logo-arq-svg .arq-serif {
						font-family: 'Cormorant Garamond', Georgia, 'Times New Roman', serif;
						font-weight: 700;
						font-size: 22px;
						letter-spacing: 0.22em;
						text-anchor: middle;
						fill: #f5f0e8;
					}
				</style>
				<text x="120" y="92" class="arq-sans">MANUEL</text>
				<text x="120" y="128" class="arq-serif" style="paint-order: stroke fill; stroke: #2a2520; stroke-width: 0.35px">
					PARADA
				</text>
				<text x="120" y="154" class="arq-sans">ESCULTOR</text>
			</svg>
		</span>
	)
}
